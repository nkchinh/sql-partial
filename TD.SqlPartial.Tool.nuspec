<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <id>TD.SqlPartial.Tool</id>
        <version>1.1.0-alpha</version>
        <authors>chinhnk</authors>
        <description>Source Generator for generating partial classes from SQL files with configurable modifiers. Modern replacement for MSBuild task version.</description>
        <tags>sqlpartial sourcegenerator dotnet sql tool</tags>
        <readme>README.md</readme>
        <developmentDependency>true</developmentDependency>
    </metadata>
    <files>
        <!-- Generator DLL -->
        <file src="src/TD.SqlPartial.Generator/bin/Release/netstandard2.0/TD.SqlPartial.Generator.dll" target="analyzers/dotnet/cs" />
        
        <!-- Build files -->
        <file src="TD.SqlPartial.Tool.targets" target="build" />

        <!-- Documentation -->
        <file src="README.md" target="" />
    </files>
</package>
