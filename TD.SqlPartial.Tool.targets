<Project>

    <UsingTask TaskName="ProcessSqlFile" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
        <ParameterGroup>
            <SqlFile ParameterType="System.String" Required="true" />
            <Namespace ParameterType="System.String" Required="true" />
            <ClassName ParameterType="System.String" Required="true" />
            <ClassModifier ParameterType="System.String" Required="false" />
            <ConstName ParameterType="System.String" Required="true" />
            <ConstModifier ParameterType="System.String" Required="false" />
            <OutputFile ParameterType="System.String" Required="true" Output="true" />
        </ParameterGroup>
        <Task>
            <Using Namespace="System.IO" />
            <Using Namespace="System.Text.RegularExpressions" />
            <Code Type="Fragment" Language="cs">
                <![CDATA[
    bool IsValidIdentifier(string identifier)
    {
        return !string.IsNullOrWhiteSpace(identifier) &&
                Regex.IsMatch(identifier, @"^[a-zA-Z_]\w*$");
    }

    bool IsValidNamespace(string identifier)
    {
        return !string.IsNullOrWhiteSpace(identifier) &&
                Regex.IsMatch(identifier, @"^[a-zA-Z_][\w.]*$");
    }

    string CleanSqlString(string sql)
    {
        if (string.IsNullOrEmpty(sql))
            return string.Empty;

        // Using StringReader for line-by-line processing without loading entire file
        using var reader = new System.IO.StringReader(sql);
        var builder = new System.Text.StringBuilder(sql.Length);
        string? line;
        bool isFirstLine = true;

        while ((line = reader.ReadLine()) != null)
        {
            // Skip if line is empty, whitespace only, or starts with --
            if (string.IsNullOrWhiteSpace(line) || line.TrimStart().StartsWith("--"))
                continue;

            // Add newline before non-first lines
            if (!isFirstLine)
                builder.AppendLine();
            else
                isFirstLine = false;

            builder.Append(line);
        }

        return builder.ToString();
    }

    if (IsValidNamespace(Namespace) && IsValidIdentifier(ClassName) && IsValidIdentifier(ConstName))
    {
        string content = File.ReadAllText(SqlFile);
        string pattern = @"--\s*#testpart.*?--\s*/testpart\s*";
        string result = Regex.Replace(content, pattern, string.Empty, RegexOptions.Singleline);
        result = CleanSqlString(result).Replace("\"", "\"\"");

        // Handle modifiers
        string classModifier = string.IsNullOrWhiteSpace(ClassModifier) ? "public" : ClassModifier.Trim();
        string constModifier = string.IsNullOrWhiteSpace(ConstModifier) ? "internal" : ConstModifier.Trim();

        var code = $@"//------------------------------------------------------------------------------
// <auto-generated>
//     Changes to this file may cause incorrect behavior and will be lost if
//     the code is regenerated.
//
//     Source: {SqlFile}
// </auto-generated>
//------------------------------------------------------------------------------
namespace {Namespace} {{
    {classModifier} partial class {ClassName} {{
        {constModifier} const string {ConstName} = @""{result}"";
    }}
}}";

        string directoryPath = Path.GetDirectoryName(OutputFile);

        if (!System.IO.Directory.Exists(directoryPath))
        {
            System.IO.Directory.CreateDirectory(directoryPath);
        }

        System.IO.File.WriteAllText(OutputFile, code);
    }
]]>
            </Code>
        </Task>
    </UsingTask>

    <Target Name="PartializeSqlFiles"
          BeforeTargets="BeforeCompile;CoreCompile"
          DependsOnTargets="PrepareForBuild;CorePartializeSqlFiles" />

    <Target Name="CorePartializeSqlFiles"
        Inputs="@(SqlPartial);$(MSBuildThisFile);$(MSBuildProjectDirectory)$(MSBuildProjectName).csproj"
        Outputs="$(IntermediateOutputPath)sqlpartials/%(SqlPartial.RelativeDir)%(SqlPartial.Filename).cs">

        <ItemGroup>
            <!-- Ensure the generated assemblyinfo file is not already part of the Compile sources -->
            <Compile Remove="$(IntermediateOutputPath)sqlpartials/%(SqlPartial.RelativeDir)%(SqlPartial.Filename).cs" />
        </ItemGroup>

        <ProcessSqlFile SqlFile="%(SqlPartial.Identity)"
                        Namespace="$(RootNamespace).$([System.String]::Copy(%(SqlPartial.RelativeDir)).Replace('/', '.').Replace('\', '.').TrimEnd('.'))"
                        ClassName="$([System.IO.Path]::GetFileNameWithoutExtension(%(SqlPartial.Filename)))"
                        ClassModifier="%(SqlPartial.ClassModifier)"
                        ConstName="Sql$([System.String]::Copy(%(SqlPartial.Filename)).Split('.', 2)[1])"
                        ConstModifier="%(SqlPartial.ConstModifier)"
                        OutputFile="$(IntermediateOutputPath)sqlpartials/%(SqlPartial.RelativeDir)%(SqlPartial.Filename).cs"
                        Condition="'@(SqlPartial)' != ''"
        >
            <Output TaskParameter="OutputFile" ItemName="Compile" />
        </ProcessSqlFile>

    </Target>

    <Target Name="CleanSqlPartializedOutputs" BeforeTargets="CoreCompile">
        <ItemGroup>
            <ExpectedFiles Include="$(IntermediateOutputPath)sqlpartials/%(SqlPartial.RelativeDir)%(SqlPartial.Filename).cs"
                Condition="'@(SqlPartial)' != ''" />
            <ProcessedFiles
                Include="$(IntermediateOutputPath)sqlpartials/**/*.cs"
                Exclude="@(ExpectedFiles)" />
        </ItemGroup>

        <Delete Files="@(ProcessedFiles)" />

        <ItemGroup>
            <OutputDirectories
                Include="$([System.IO.Directory]::GetDirectories('$(IntermediateOutputPath)sqlpartials', '*', System.IO.SearchOption.AllDirectories))" />

            <OutputDirectories>
                <Files>$([System.IO.Directory]::GetFiles("%(OutputDirectories.Identity)", "*", System.IO.SearchOption.AllDirectories).get_Length())</Files>
            </OutputDirectories>
        </ItemGroup>

        <!-- Remove empty directories from bottom up -->
        <RemoveDir Directories="@(OutputDirectories)" Condition="%(Files)=='0'" />
    </Target>
</Project>
